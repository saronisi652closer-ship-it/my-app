<!doctype html>

<html lang="ja">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>遊戯王所持カード一覧</title>
  <link rel="stylesheet" href="../../style.css">
  <style>
    .list{
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .item{
      background:#10131b;
      border:1px solid var(--line);
      border-radius:14px;
      padding:12px;
    }
    .item-head{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:flex-start;
    }
    .item-name{
      font-weight:700;
      line-height:1.5;
    }
    .count-badge{
      display:inline-block;
      padding:6px 10px;
      border-radius:999px;
      border:1px solid var(--line);
      background:#0f1117;
      font-size:12px;
      white-space:nowrap;
    }
    .summary-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:10px;
    }
    @media(max-width:700px){
      .summary-grid{grid-template-columns:1fr}
      .item-head{flex-direction:column}
    }
  </style>
</head>
<body>
  <header>
    <div class="wrap">
      <h1>遊戯王所持カード一覧</h1>
      <div class="small">所持枚数の確認・編集・削除</div>
    </div>
  </header>  <main class="wrap">
    <a class="back" href="../">← 遊戯王へ戻る</a><div class="grid">
  <section class="card">
    <h2 id="editorTitle">所持カード編集</h2>

    <div class="two">
      <div>
        <div class="label">カード名</div>
        <input id="cardName" type="text" placeholder="例：灰流うらら">
      </div>
      <div>
        <div class="label">所持枚数</div>
        <input id="cardCount" type="number" min="0" max="99" placeholder="例：3">
      </div>
    </div>

    <div class="row" style="margin-top:12px;">
      <button class="primary" id="saveBtn" type="button">保存</button>
      <button id="clearBtn" type="button">入力クリア</button>
      <button class="danger" id="deleteBtn" type="button" style="display:none;">削除</button>
    </div>

    <div class="small" id="statusText" style="margin-top:10px;"></div>

    <div class="card" style="margin-top:12px;">
      <h2>集計</h2>
      <div class="summary-grid">
        <div class="mini-card"><strong>登録種類数</strong><div id="summaryKinds">0</div></div>
        <div class="mini-card"><strong>総枚数</strong><div id="summaryTotal">0</div></div>
        <div class="mini-card"><strong>3枚以上</strong><div id="summaryPlayset">0</div></div>
      </div>
    </div>
  </section>

  <section class="card">
    <h2>登録済み所持カード</h2>

    <div class="two" style="margin-bottom:12px;">
      <div>
        <div class="label">検索</div>
        <input id="searchBox" type="text" placeholder="カード名で検索">
      </div>
      <div>
        <div class="label">並び順</div>
        <select id="sortBox">
          <option value="name_asc">カード名順</option>
          <option value="count_desc">枚数が多い順</option>
          <option value="updated_desc">更新が新しい順</option>
        </select>
      </div>
    </div>

    <div id="cardList" class="list"></div>
    <div id="emptyMessage" class="small">まだ所持カードがありません。</div>
  </section>
</div>

  </main>  <script>
    (() => {
      const STORAGE_KEY = "yugioh_owned_cards_v1";

      const $ = (id) => document.getElementById(id);

      const editorTitle = $("editorTitle");
      const cardName = $("cardName");
      const cardCount = $("cardCount");
      const saveBtn = $("saveBtn");
      const clearBtn = $("clearBtn");
      const deleteBtn = $("deleteBtn");
      const statusText = $("statusText");

      const searchBox = $("searchBox");
      const sortBox = $("sortBox");
      const cardList = $("cardList");
      const emptyMessage = $("emptyMessage");

      const summaryKinds = $("summaryKinds");
      const summaryTotal = $("summaryTotal");
      const summaryPlayset = $("summaryPlayset");

      let items = loadItems();
      let editingId = null;

      function createId(prefix = "owned") {
        return `${prefix}_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
      }

      function loadItems() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          return raw ? JSON.parse(raw) : [];
        } catch (e) {
          return [];
        }
      }

      function saveItems() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
      }

      function escapeHtml(text) {
        return String(text ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function setStatus(message) {
        statusText.textContent = message;
        if (message) {
          setTimeout(() => {
            if (statusText.textContent === message) statusText.textContent = "";
          }, 2500);
        }
      }

      function clearForm() {
        editingId = null;
        editorTitle.textContent = "所持カード編集";
        cardName.value = "";
        cardCount.value = "";
        deleteBtn.style.display = "none";
      }

      function fillForm(item) {
        editingId = item.id;
        editorTitle.textContent = `編集中：${item.name}`;
        cardName.value = item.name || "";
        cardCount.value = item.count ?? "";
        deleteBtn.style.display = "inline-block";
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      function updateSummary() {
        const totalKinds = items.length;
        const totalCards = items.reduce((sum, item) => sum + Number(item.count || 0), 0);
        const playsetCount = items.filter(item => Number(item.count || 0) >= 3).length;

        summaryKinds.textContent = String(totalKinds);
        summaryTotal.textContent = String(totalCards);
        summaryPlayset.textContent = String(playsetCount);
      }

      function saveItem() {
        const name = cardName.value.trim();
        const count = Number(cardCount.value || 0);

        if (!name) {
          setStatus("カード名を入れてください");
          return;
        }

        const now = new Date().toISOString();

        if (editingId) {
          const index = items.findIndex(item => item.id === editingId);
          if (index >= 0) {
            items[index] = {
              ...items[index],
              name,
              count,
              updatedAt: now
            };
            saveItems();
            renderList();
            fillForm(items[index]);
            setStatus("更新しました");
            return;
          }
        }

        const existingByName = items.find(item => item.name === name);
        if (existingByName) {
          existingByName.count = count;
          existingByName.updatedAt = now;
          saveItems();
          renderList();
          fillForm(existingByName);
          setStatus("更新しました");
          return;
        }

        const newItem = {
          id: createId(),
          name,
          count,
          createdAt: now,
          updatedAt: now
        };

        items.unshift(newItem);
        saveItems();
        renderList();
        fillForm(newItem);
        setStatus("保存しました");
      }

      function deleteCurrentItem() {
        if (!editingId) return;

        const target = items.find(item => item.id === editingId);
        if (!target) return;

        const ok = confirm(`「${target.name}」を削除しますか？`);
        if (!ok) return;

        items = items.filter(item => item.id !== editingId);
        saveItems();
        clearForm();
        renderList();
        setStatus("削除しました");
      }

      function getFilteredItems() {
        const keyword = searchBox.value.trim().toLowerCase();
        const sort = sortBox.value;

        let result = [...items];

        if (keyword) {
          result = result.filter(item => String(item.name || "").toLowerCase().includes(keyword));
        }

        if (sort === "name_asc") {
          result.sort((a, b) => String(a.name || "").localeCompare(String(b.name || ""), "ja"));
        } else if (sort === "count_desc") {
          result.sort((a, b) => Number(b.count || 0) - Number(a.count || 0) || String(a.name || "").localeCompare(String(b.name || ""), "ja"));
        } else if (sort === "updated_desc") {
          result.sort((a, b) => String(b.updatedAt || "").localeCompare(String(a.updatedAt || "")));
        }

        return result;
      }

      function renderList() {
        const filtered = getFilteredItems();
        cardList.innerHTML = "";
        emptyMessage.style.display = filtered.length ? "none" : "block";

        filtered.forEach(item => {
          const el = document.createElement("div");
          el.className = "item";
          el.innerHTML = `
            <div class="item-head">
              <div>
                <div class="item-name">${escapeHtml(item.name)}</div>
                <div class="small" style="margin-top:6px;">最終更新：${escapeHtml((item.updatedAt || "").replace("T", " ").slice(0, 16))}</div>
              </div>
              <div class="count-badge">${escapeHtml(item.count)} 枚</div>
            </div>
            <div class="row" style="margin-top:12px;">
              <button type="button" data-role="edit" data-id="${escapeHtml(item.id)}">編集</button>
              <button type="button" data-role="plus" data-id="${escapeHtml(item.id)}">+1</button>
              <button type="button" data-role="minus" data-id="${escapeHtml(item.id)}">-1</button>
              <button type="button" class="danger" data-role="delete" data-id="${escapeHtml(item.id)}">削除</button>
            </div>
          `;
          cardList.appendChild(el);
        });

        cardList.querySelectorAll('button[data-role="edit"]').forEach(btn => {
          btn.addEventListener("click", () => {
            const target = items.find(item => item.id === btn.dataset.id);
            if (target) fillForm(target);
          });
        });

        cardList.querySelectorAll('button[data-role="plus"]').forEach(btn => {
          btn.addEventListener("click", () => {
            const target = items.find(item => item.id === btn.dataset.id);
            if (!target) return;
            target.count = Number(target.count || 0) + 1;
            target.updatedAt = new Date().toISOString();
            saveItems();
            renderList();
          });
        });

        cardList.querySelectorAll('button[data-role="minus"]').forEach(btn => {
          btn.addEventListener("click", () => {
            const target = items.find(item => item.id === btn.dataset.id);
            if (!target) return;
            target.count = Math.max(0, Number(target.count || 0) - 1);
            target.updatedAt = new Date().toISOString();
            saveItems();
            renderList();
          });
        });

        cardList.querySelectorAll('button[data-role="delete"]').forEach(btn => {
          btn.addEventListener("click", () => {
            const target = items.find(item => item.id === btn.dataset.id);
            if (!target) return;
            const ok = confirm(`「${target.name}」を削除しますか？`);
            if (!ok) return;
            items = items.filter(item => item.id !== btn.dataset.id);
            saveItems();
            if (editingId === btn.dataset.id) clearForm();
            renderList();
            setStatus("削除しました");
          });
        });

        updateSummary();
      }

      saveBtn.addEventListener("click", saveItem);
      clearBtn.addEventListener("click", () => {
        clearForm();
        setStatus("入力をクリアしました");
      });
      deleteBtn.addEventListener("click", deleteCurrentItem);

      searchBox.addEventListener("input", renderList);
      sortBox.addEventListener("change", renderList);

      clearForm();
      renderList();
    })();
  </script></body>
</html>
